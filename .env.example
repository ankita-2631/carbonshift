# Azure AI Foundry project endpoint, e.g. https://<your-project>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=

# Chat model deployment name (e.g. gpt-4o)
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o

# Optional: Foundry IQ knowledge base / index name
FOUNDRY_IQ_INDEX=carbon-knowledge

# Azure AI Search endpoint backing Foundry IQ, e.g. https://<your-search>.search.windows.net
SEARCH_ENDPOINT=

# Carbon data source (UK Carbon Intensity API needs no key)
CARBON_API_BASE=https://api.carbonintensity.org.uk

# Organization travel booking app (e.g. SAP Concur, TravelPerk, Egencia).
# JSON endpoint returning a list of bookings. Leave blank to use bundled demo trips.
TRAVEL_APP_API=
TRAVEL_APP_TOKEN=

# Organization compute scheduler / batch queue (e.g. Airflow, K8s CronJobs, Slurm).
# JSON endpoint returning a list of jobs. Leave blank to use bundled demo jobs.
JOBS_API=
JOBS_API_TOKEN=
